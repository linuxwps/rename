{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Main permissions for file operations",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-stat",
    "fs:allow-read-dir",
    "fs:allow-exists",
    "fs:allow-rename",
    "fs:allow-write-text-file",
    "fs:allow-read-text-file",
    "fs:allow-remove",
    "os:default"
  ]
}